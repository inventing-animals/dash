<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Dash.Client"
             x:Class="Dash.Client.App"
             xmlns:themes="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             RequestedThemeVariant="Default">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <StyleInclude Source="avares://Ink.UI/Themes/InkTheme.axaml" />
        <themes:ShadTheme />
    </Application.Styles>
</Application>